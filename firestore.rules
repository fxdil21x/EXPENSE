rules_version = '2';

// Keep this list in sync with VITE_ADMIN_EMAILS in your .env file.
// These emails are auto-approved as admins on first sign-in, and only
// this rules-level list (backed by the server-verified auth token) decides
// who is allowed to self-assign the admin role — the client's write request
// cannot be trusted for that decision.
function isAdminEmail(email) {
  return email in ['fadilfadu90@gmail.com'];
}

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isApprovedAdmin() {
      return isSignedIn() && myProfile().role == 'admin' && myProfile().status == 'approved';
    }

    function isApprovedSelf(uid) {
      return isSelf(uid) && myProfile().status == 'approved';
    }

    match /users/{uid} {
      allow read: if isSelf(uid) || isApprovedAdmin();

      allow create: if isSelf(uid)
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.role == (isAdminEmail(request.auth.token.email) ? 'admin' : 'member')
        && request.resource.data.status == (isAdminEmail(request.auth.token.email) ? 'approved' : 'pending');

      // Admins can change status/role on anyone. A user may update their own
      // profile fields (e.g. displayName/photoURL refresh) but never their
      // own role or status.
      allow update: if isApprovedAdmin()
        || (isSelf(uid)
            && request.resource.data.role == resource.data.role
            && request.resource.data.status == resource.data.status);

      allow delete: if false;

      match /categories/{categoryId} {
        allow read, write: if isApprovedSelf(uid);
      }

      match /expenses/{expenseId} {
        allow read, write: if isApprovedSelf(uid);
      }
    }
  }
}
